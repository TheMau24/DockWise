# DockWise - variables de entorno (PLANTILLA, sin valores reales)
# Copia este archivo y completa los valores en .env / .env.local (no commitear).

# Conexión Postgres vía Supabase Session Pooler. Debe incluir schema=dockwise.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.pooler.supabase.com:5432/postgres?schema=dockwise"

# URL pública del proyecto Supabase.
NEXT_PUBLIC_SUPABASE_URL="https://szeytroaxkpncqifdszc.supabase.co"

# Clave anónima pública (segura para el cliente).
NEXT_PUBLIC_SUPABASE_ANON_KEY="tu-anon-key"

# Clave service role: SOLO en servidor. Nunca exponer al cliente ni commitear.
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key"
